  cron: 00 * * * * *
  keycloakclient:
    realms: greatsokol,master,APIM,FINSTAR
    url: https://lemur-16.cloud-iam.com/auth/realms/greatsokol
    client: admin-cli
    admin:
      realm: greatsokol
      login: admin
      password: ${kсpwd:LIONlion1979!}
    inactivity:
