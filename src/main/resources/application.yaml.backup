server:
  port: 9000
spring:
  security:
    oauth2:
      resourceserver:
        jwt:
          issuer-uri: ${front.issuer-uri}
      client:
        provider:
          keycloak:
            issuer-uri: ${front.issuer-uri}
            user-name-attribute: preferred_username
        registration:
          keycloak:
            client-id: ${front.client-id}
            client-secret: ${front.client-secret}
            scope: openid
  jpa:
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
  datasource:
    driver-class-name: org.postgresql.Driver
    url: ${db.url}
    username: ${db.username}
    password: ${db.password}


#-----------------------------------------------------------------------------
db:
  url: jdbc:postgresql://localhost:5433/postgres?currentSchema=kcusers
  username: postgres
  password: ${pgpwd:admin}

#-----------------------------------------------------------------------------
front:
  issuer-uri: https://lemur-16.cloud-iam.com/auth/realms/greatsokol
  client-id: test_client
  client-secret: ${clsec:UqFI6b8az9RoTs6r4QkXXu7QdgUbBpMm}
  userroles: user
  adminroles: admin
  pagesize: 10

#-----------------------------------------------------------------------------
